<?xml version="1.0" encoding="utf-8"?>
<!--
  路径: app/src/main/res/layout/dialog_privacy_consent.xml
  用途: AI 影伴系统 v1.0 — 患者端隐私确认弹窗
  触发: 收到监护人 device_control_request 时弹出
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <!-- 隐私图标 -->
    <TextView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="🔒"
        android:textSize="36sp"
        android:gravity="center"
        android:background="@drawable/bg_privacy_icon"
        android:layout_marginBottom="16dp" />

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/privacy_dialog_title"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp" />

    <!-- 提示信息 -->
    <TextView
        android:id="@+id/tv_privacy_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/privacy_dialog_message"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <!-- 按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_privacy_decline"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/privacy_dialog_decline"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_privacy_share"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/privacy_dialog_share"
            android:textSize="14sp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
