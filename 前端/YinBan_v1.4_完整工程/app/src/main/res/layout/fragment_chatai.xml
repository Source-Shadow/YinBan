<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/yb_night_bg_page"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="ifContentScrolls"
    android:paddingStart="@dimen/yb_spacing_20"
    android:paddingTop="@dimen/yb_spacing_20"
    android:paddingEnd="@dimen/yb_spacing_20"
    android:paddingBottom="@dimen/yb_spacing_24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="168dp"
            android:layout_height="168dp"
            android:layout_marginTop="@dimen/yb_spacing_12"
            android:background="@drawable/yb_ai_entry_hero_halo">

            <ImageView
                android:id="@+id/iv_ai_entry_logo"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="小影火"
                android:scaleType="centerInside"
                android:src="@drawable/yb_xiaoyinghuo_idle" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/yb_spacing_20"
            android:background="@drawable/yb_night_bg_glass_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/yb_spacing_20"
            android:paddingTop="@dimen/yb_spacing_24"
            android:paddingEnd="@dimen/yb_spacing_20"
            android:paddingBottom="@dimen/yb_spacing_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="小影火"
                android:textColor="@color/yb_color_night_text_primary"
                android:textSize="28sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/yb_spacing_12"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="你好呀～我是小影火&#10;你的温暖陪伴伙伴，随时在这儿陪着你。"
                android:textColor="@color/yb_color_night_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/yb_spacing_16"
            android:background="@drawable/yb_ai_entry_status_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/yb_spacing_16"
            android:paddingTop="@dimen/yb_spacing_12"
            android:paddingEnd="@dimen/yb_spacing_16"
            android:paddingBottom="@dimen/yb_spacing_12">

            <View
                android:id="@+id/view_ai_status_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/yb_ai_entry_status_dot"
                android:backgroundTint="@color/yb_color_status_warning" />

            <TextView
                android:id="@+id/tv_ai_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/yb_spacing_12"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="小影火 直连"
                android:textColor="@color/yb_color_status_warning"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_chat"
            android:layout_width="match_parent"
            android:layout_height="@dimen/yb_size_button_height"
            android:layout_marginTop="@dimen/yb_spacing_24"
            android:contentDescription="开始与影火AI对话"
            android:fontFamily="sans-serif-medium"
            android:text="开始对话"
            android:textColor="@color/yb_color_night_text_primary"
            android:textSize="17sp"
            app:backgroundTint="@color/yb_color_primary"
            app:cornerRadius="@dimen/yb_radius_medium"
            app:icon="@drawable/yb_ic_ai_chat"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/yb_spacing_8"
            app:iconTint="@color/yb_color_night_text_primary" />
    </LinearLayout>
</ScrollView>
