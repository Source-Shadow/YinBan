<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text style names map to spec tokens: yb_text_display, yb_text_page_title, etc. -->
    <style name="Yb.Text.Display" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/yb_color_text_primary</item>
    </style>

    <style name="Yb.Text.PageTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">34sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/yb_color_text_primary</item>
    </style>

    <style name="Yb.Text.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">26sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/yb_color_text_primary</item>
    </style>

    <style name="Yb.Text.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/yb_color_text_primary</item>
    </style>

    <style name="Yb.Text.BodySecondary" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/yb_color_text_secondary</item>
    </style>

    <style name="Yb.Text.Status" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">13sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/yb_color_text_secondary</item>
    </style>

    <style name="Yb.Text.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">17sp</item>
        <item name="android:lineHeight">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/yb_color_surface</item>
    </style>

    <style name="Yb.Text.Data" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">26sp</item>
        <item name="android:lineHeight">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/yb_color_text_primary</item>
    </style>

    <style name="Yb.Night.Text.Display" parent="Yb.Text.Display">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>

    <style name="Yb.Night.Text.PageTitle" parent="Yb.Text.PageTitle">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>

    <style name="Yb.Night.Text.SectionTitle" parent="Yb.Text.SectionTitle">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>

    <style name="Yb.Night.Text.Body" parent="Yb.Text.Body">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>

    <style name="Yb.Night.Text.BodySecondary" parent="Yb.Text.BodySecondary">
        <item name="android:textColor">@color/yb_color_night_text_secondary</item>
    </style>

    <style name="Yb.Night.Text.Status" parent="Yb.Text.Status">
        <item name="android:textColor">@color/yb_color_night_text_secondary</item>
    </style>

    <style name="Yb.Night.Text.Button" parent="Yb.Text.Button">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>

    <style name="Yb.Night.Text.Data" parent="Yb.Text.Data">
        <item name="android:textColor">@color/yb_color_night_text_primary</item>
    </style>
</resources>
