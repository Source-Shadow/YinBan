<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/yb_color_night_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/yb_color_night_border_strong" />
        </shape>
    </item>
    <item
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp"
        android:top="18dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerColor="@color/yb_color_night_surface"
                android:endColor="@android:color/transparent"
                android:gradientRadius="72dp"
                android:startColor="@color/yb_color_night_surface_strong" />
        </shape>
    </item>
</layer-list>
