<?xml version="1.0" encoding="utf-8"?>
<!--
  路径: app/src/main/res/layout/activity_guardian.xml
  布局: 状态 + SOS面板 + 看板 + 视频画面(4:5) + 控制按钮
  消息: 点击按钮跳转 ChatActivity
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── 顶部标题 ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp" app:cardElevation="2dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:padding="12dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/guardian_title"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />
                <TextView android:id="@+id/tv_guardian_connection"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🟡 等待配对" android:textSize="12sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="3dp">
                <TextView android:text="房间: " android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_guardian_room"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="----" android:textSize="11sp"
                    android:textColor="@color/primary" android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── SOS 紧急警报 ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_sos_alert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        app:cardCornerRadius="14dp" app:cardElevation="6dp"
        app:strokeWidth="3dp" app:strokeColor="@color/error"
        app:cardBackgroundColor="#FFFFF5F5">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:padding="12dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:text="🚨" android:textSize="20sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:text="紧急求助！" android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/error" android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
            <TextView android:id="@+id/tv_sos_message"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:text="患者发出紧急求助"
                android:textSize="13sp" android:textColor="@color/text_primary" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="4dp">
                <TextView android:text="📍 " android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_sos_location"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textSize="11sp"
                    android:textColor="@color/primary" android:fontFamily="sans-serif-medium" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sos_view_video"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:text="📺 查看画面"
                    android:textSize="11sp" app:cornerRadius="10dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sos_dismiss"
                    android:layout_width="0dp" android:layout_height="40dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    android:text="已处理" android:textSize="11sp"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── 实时数据看板 ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="14dp" app:cardElevation="2dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:padding="12dp">
            <TextView android:text="📊 实时数据" android:textSize="14sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="4dp">
                <TextView android:id="@+id/tv_location_lat"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="纬度: --"
                    android:textSize="12sp" android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_location_lng"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="经度: --"
                    android:textSize="12sp" android:textColor="@color/text_secondary" />
            </LinearLayout>
            <TextView android:id="@+id/tv_location_accuracy"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="精度: --"
                android:textSize="11sp" android:textColor="@color/text_secondary" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="6dp"
                android:background="@color/text_secondary" android:alpha="0.12" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/tv_camera_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="摄像头: ⚪"
                    android:textSize="12sp" android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_headphone_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="耳机: ⚪"
                    android:textSize="12sp" android:textColor="@color/text_secondary" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="6dp"
                android:background="@color/text_secondary" android:alpha="0.12" />
            <TextView android:text="💬 患者消息" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium" android:textColor="@color/text_primary" />
            <TextView android:id="@+id/tv_patient_message"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="3dp" android:text="--"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                android:minHeight="32dp" android:gravity="center_vertical"
                android:padding="8dp" android:background="@drawable/bg_message_bubble" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════ 视频画面 weight=4 (占 4/5) ═══════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_guardian_video"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="18dp" app:cardElevation="2dp"
        app:cardBackgroundColor="@color/video_container_bg">

        <FrameLayout android:layout_width="match_parent"
            android:layout_height="match_parent">
            <SurfaceView android:id="@+id/surface_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:visibility="gone" />
            <WebView android:id="@+id/web_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
            <TextView android:id="@+id/tv_guardian_video_placeholder"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="📺\n等待患者画面"
                android:textSize="16sp" android:textColor="@color/text_on_dark"
                android:gravity="center" android:alpha="0.5"
                android:lineSpacingExtra="6dp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════ 控制按钮 weight=1 (占 1/5) ═══════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_controls"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp" android:layout_marginBottom="8dp"
        app:cardCornerRadius="14dp" app:cardElevation="2dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="match_parent" android:orientation="vertical"
            android:padding="10dp" android:gravity="center_vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardian_go_chat"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="💬 消息"
                    android:textSize="11sp" app:cornerRadius="10dp"
                    android:textColor="@color/primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardian_video_call"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    android:text="📹 视频通话" android:textSize="11sp"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardian_audio_call"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    android:text="🎙️ 语音通话" android:textSize="11sp"
                    app:cornerRadius="10dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_guardian_logout"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:layout_marginTop="6dp" android:text="退出登录"
                android:textSize="11sp" android:textColor="@color/error"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
