<?xml version="1.0" encoding="utf-8"?>
<!-- 监护人端 v2.0 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp" android:paddingVertical="12dp"
        android:background="@drawable/bg_message_bubble"
        android:elevation="1dp">
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/bg_step_active" android:id="@+id/dot_status" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="10dp">
            <TextView android:text="监护人端" android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/tv_guardian_connection"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="等待配对" android:textSize="11sp"
                android:textColor="@color/status_waiting_text" />
        </LinearLayout>
        <TextView android:id="@+id/tv_guardian_room"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="----" android:textSize="11sp"
            android:textColor="@color/text_tertiary" />
    </LinearLayout>

    <!-- SOS 紧急警报面板 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_sos_alert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp" app:cardElevation="6dp"
        app:strokeWidth="3dp" app:strokeColor="@color/sos_red"
        app:cardBackgroundColor="#FFFEF2F2">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:padding="16dp">
            <TextView android:text="🚨 紧急求助！" android:textSize="18sp"
                android:textColor="@color/sos_red"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <TextView android:id="@+id/tv_sos_message"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="患者发出紧急求助"
                android:textSize="14sp" android:textColor="@color/text_primary" />
            <TextView android:id="@+id/tv_sos_location"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="📍 --"
                android:textSize="12sp" android:textColor="@color/primary" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sos_view_video"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="📺 查看画面"
                    android:textSize="13sp" app:cornerRadius="14dp"
                    app:backgroundTint="@color/sos_red" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sos_dismiss"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:text="已处理" android:textSize="13sp"
                    app:cornerRadius="14dp" android:textColor="@color/text_secondary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 数据看板 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="20dp" app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:padding="16dp">
            <TextView android:text="📊 实时数据" android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:id="@+id/tv_location_lat"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="纬度: --"
                    android:textSize="13sp" android:textColor="@color/text_primary" />
                <TextView android:id="@+id/tv_location_lng"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="经度: --"
                    android:textSize="13sp" android:textColor="@color/text_primary" />
            </LinearLayout>
            <TextView android:id="@+id/tv_location_accuracy"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="精度: --"
                android:textSize="11sp" android:textColor="@color/text_tertiary" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/surface_variant" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:id="@+id/tv_camera_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="摄像头: ⚪"
                    android:textSize="13sp" android:textColor="@color/text_secondary" />
                <TextView android:id="@+id/tv_headphone_status"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="耳机: ⚪"
                    android:textSize="13sp" android:textColor="@color/text_secondary" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="8dp"
                android:background="@color/surface_variant" />
            <TextView android:text="💬 患者消息" android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/tv_patient_message"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="--"
                android:textSize="13sp" android:textColor="@color/text_primary"
                android:minHeight="36dp" android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_message_bubble" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 视频画面 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_guardian_video"
        android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="24dp" app:cardElevation="2dp"
        app:cardBackgroundColor="@color/video_container_bg">
        <FrameLayout android:layout_width="match_parent"
            android:layout_height="match_parent">
            <SurfaceView android:id="@+id/surface_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:visibility="gone" />
            <WebView android:id="@+id/web_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:visibility="gone" />
            <TextView android:id="@+id/tv_guardian_video_placeholder"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="📺\n等待患者画面"
                android:textSize="16sp" android:textColor="@color/text_on_dark"
                android:gravity="center" android:alpha="0.5"
                android:lineSpacingExtra="6dp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginVertical="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardian_go_chat"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="💬 消息" android:textSize="13sp"
            app:cornerRadius="16dp" android:textColor="@color/primary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardian_video_call"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginHorizontal="4dp"
            android:text="📹 视频通话" android:textSize="13sp"
            app:cornerRadius="16dp" android:textColor="@color/primary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardian_audio_call"
            android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:layout_marginStart="6dp"
            android:text="🎙️ 语音" android:textSize="13sp"
            app:cornerRadius="16dp" android:textColor="@color/primary"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_guardian_logout"
        android:layout_width="match_parent" android:layout_height="44dp"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:text="退出登录" android:textSize="12sp"
        android:textColor="@color/text_tertiary"
        app:cornerRadius="16dp"
        style="@style/Widget.MaterialComponents.Button.TextButton" />

</LinearLayout>
